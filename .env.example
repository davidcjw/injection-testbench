# Used by the CLI (`npm run eval`) for both the system-under-test and the judge.
# The WEB APP does NOT read this — it requires a key pasted in the UI (BYOK),
# so a public deployment never spends the owner's credits.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides. Default to claude-opus-4-8 for both.
# TARGET_MODEL is the model being attacked (the "system under test").
# JUDGE_MODEL grades whether a response was compromised — try a weaker model
# here to study how a fool-able judge disagrees with the canary verdict.
# QUARANTINE_MODEL is the sandboxed LLM used by the Dual-LLM defense to process
# untrusted content; it holds no secrets and no tools, so a cheaper model fits.
# TARGET_MODEL=claude-opus-4-8
# JUDGE_MODEL=claude-opus-4-8
# QUARANTINE_MODEL=claude-opus-4-8

# Optional: enables per-IP rate limiting on /api/eval (protects compute on a
# public deploy). Create a free Upstash Redis DB and paste its REST creds.
# If unset, the limiter is a no-op and all requests are allowed.
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
